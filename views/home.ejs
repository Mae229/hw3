<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HW3: World Explorer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <h1 class="site-header">🌍 World Explorer</h1>
    <%- include('partials/navbar') %>

    <main class="container mt-4">
        <h2 class="page-title">Welcome!</h2>
        <p class="lead">Discover countries and check the weather around the world.</p>

        <div class="card country-card mt-4">
            <div class="card-body">
                <h3 class="card-title">🎲 Random Country of the Day</h3>
                <h4><strong><%= country.name %></strong> (<%= code %>)</h4>
                <p><strong>Capital:</strong> <%= country.capital %></p>
                <p><strong>Continent:</strong> <%= country.continent %></p>
                <p><strong>Currency:</strong> <%= country.currency.join(', ') %></p>
                <p><strong>Phone code:</strong> +<%= country.phone.join(', +') %></p>
                <a href="/country?code=<%= code %>" class="btn btn-primary">More details</a>
            </div>
        </div>

        <div class="mt-4 row">
            <div class="col-md-6">
                <div class="card feature-card">
                    <div class="card-body">
                        <h4>🔍 Search a Country</h4>
                        <p>Get details about any country in the world using a dropdown.</p>
                        <a href="/country" class="btn btn-outline-primary">Go to Country Info</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card feature-card">
                    <div class="card-body">
                        <h4>🌤️ Check the Weather</h4>
                        <p>Enter any city name to get live current weather data.</p>
                        <a href="/weather" class="btn btn-outline-success">Go to Weather</a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
